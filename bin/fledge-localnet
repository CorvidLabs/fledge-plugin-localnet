#!/usr/bin/env bash
set -euo pipefail

# Save original stdout for protocol messages; command substitutions
# capture stdout, so protocol writes must go to fd3 to reach the host.
exec 3>&1

# --- fledge-v1 protocol helpers ---

send() { printf '%s\n' "$1" >&3; }

recv() {
  local line
  IFS= read -r line
  printf '%s\n' "$line"
}

json_obj() { jq -cn "$@"; }

send_output() { send "$(json_obj --arg t "$1" '{type:"output",text:$t}')"; }
send_log() { send "$(json_obj --arg l "$1" --arg m "$2" '{type:"log",level:$l,message:$m}')"; }
send_error() { send_log "error" "$1"; }
send_progress() { send "$(json_obj --arg m "$1" '{type:"progress",message:$m}')"; }

send_exec() {
  local id="$1" cmd="$2"
  send "$(json_obj --arg id "$id" --arg cmd "$cmd" '{type:"exec",id:$id,command:$cmd}')"
  recv
}

send_confirm() {
  local id="$1" message="$2"
  send "$(json_obj --arg id "$id" --arg m "$message" '{type:"confirm",id:$id,message:$m}')"
  recv
}

# --- Response parsing helpers ---

resp_stdout() { printf '%s' "$1" | jq -r '.value.stdout // ""' 2>/dev/null; }
resp_stderr() { printf '%s' "$1" | jq -r '.value.stderr // ""' 2>/dev/null; }
resp_code() { printf '%s' "$1" | jq -r '.value.code // 0' 2>/dev/null; }
resp_value() { printf '%s' "$1" | jq -r '.value // empty' 2>/dev/null; }

# --- Parse init message ---

INIT=$(recv)
INIT_VERSION=$(printf '%s' "$INIT" | jq -r '.version // ""' 2>/dev/null)
if [ "$INIT_VERSION" != "fledge-v1" ]; then
  send_error "Unsupported protocol version: '$INIT_VERSION' (expected 'fledge-v1')"
  exit 1
fi
ARGS=$(printf '%s' "$INIT" | jq -r '.args // [] | .[]' 2>/dev/null)
PROJECT_ROOT=$(printf '%s' "$INIT" | jq -r '.project.root // "."' 2>/dev/null)

declare -a ARGV=()
while IFS= read -r arg; do
  [ -n "$arg" ] && ARGV+=("$arg")
done <<< "$ARGS"

SUBCMD="${ARGV[0]:-help}"

# Check for --json flag
JSON_OUTPUT=false
for arg in "${ARGV[@]}"; do
  [ "$arg" = "--json" ] && JSON_OUTPUT=true
done

send_json() { send "$(printf '%s' "$1" | jq -Rsc '{type:"output",text:.}')"; }

# --- Helper: check prerequisites ---

check_algokit() {
  local result
  result=$(send_exec "check-algokit" "which algokit")
  local exit_code
  exit_code=$(resp_code "$result")
  if [ "$exit_code" != "0" ]; then
    send_error "algokit not found. Install: https://github.com/algorandfoundation/algokit-cli"
    exit 1
  fi
}

check_docker() {
  local result
  result=$(send_exec "check-docker" "docker info > /dev/null 2>&1 && echo ok || echo fail")
  local stdout
  stdout=$(resp_stdout "$result" | tr -d '[:space:]')
  if [ "$stdout" != "ok" ]; then
    send_error "Docker must be running for localnet"
    exit 1
  fi
}

# --- Subcommands ---

cmd_start() {
  check_algokit
  check_docker
  send_progress "Starting Algorand localnet..."
  local result
  result=$(send_exec "start" "algokit localnet start")
  local exit_code
  exit_code=$(resp_code "$result")
  if [ "$exit_code" != "0" ]; then
    local stderr
    stderr=$(resp_stderr "$result")
    send_error "Failed to start localnet: $stderr"
    exit 1
  fi
  if [ "$JSON_OUTPUT" = true ]; then
    send_json '{"ok":true,"action":"start","algod":"localhost:4001","kmd":"localhost:4002","indexer":"localhost:8980"}'
  else
    send_output "Localnet started. algod: localhost:4001, KMD: localhost:4002, indexer: localhost:8980"
  fi
}

cmd_stop() {
  check_algokit
  local result
  result=$(send_exec "stop" "algokit localnet stop")
  local exit_code
  exit_code=$(resp_code "$result")
  if [ "$exit_code" != "0" ]; then
    local stderr
    stderr=$(resp_stderr "$result")
    send_error "Failed to stop localnet: $stderr"
    exit 1
  fi
  if [ "$JSON_OUTPUT" = true ]; then
    send_json '{"ok":true,"action":"stop"}'
  else
    send_output "Localnet stopped."
  fi
}

cmd_reset() {
  check_algokit
  local resp
  resp=$(send_confirm "confirm-reset" "Are you sure? This will destroy all localnet state.")
  local confirmed
  confirmed=$(resp_value "$resp")
  if [ "$confirmed" != "true" ]; then
    send_output "Cancelled."
    exit 0
  fi
  send_progress "Resetting localnet..."
  local result
  result=$(send_exec "reset" "algokit localnet reset")
  local exit_code
  exit_code=$(resp_code "$result")
  if [ "$exit_code" != "0" ]; then
    local stderr
    stderr=$(resp_stderr "$result")
    send_error "Failed to reset localnet: $stderr"
    exit 1
  fi
  if [ "$JSON_OUTPUT" = true ]; then
    send_json '{"ok":true,"action":"reset"}'
  else
    send_output "Localnet reset to genesis."
  fi
}

cmd_status() {
  check_algokit
  local docker_check
  docker_check=$(send_exec "docker-ps" "docker ps --filter name=algokit --format '{{.Names}}: {{.Status}}' 2>/dev/null")
  local containers
  containers=$(resp_stdout "$docker_check")

  if [ -z "$(printf '%s' "$containers" | tr -d '[:space:]')" ]; then
    if [ "$JSON_OUTPUT" = true ]; then
      send_json '{"status":"stopped","running":false}'
    else
      send_output "Status: stopped"
      send_output "Run: fledge localnet start"
    fi
  else
    if [ "$JSON_OUTPUT" = true ]; then
      send_json '{"status":"running","running":true,"algod":"localhost:4001","kmd":"localhost:4002","indexer":"localhost:8980"}'
    else
      send_output "Status: running"
      send_output ""
      send "$(printf '%s' "$containers" | jq -Rsc '{type:"output",text:.}')"
      send_output ""
      send_output "algod:   localhost:4001"
      send_output "KMD:     localhost:4002"
      send_output "Indexer: localhost:8980"
    fi
  fi
}

cmd_fund() {
  local address="${ARGV[1]:-}"
  if [ -z "$address" ]; then
    send_error "Usage: fledge localnet fund <address> [--amount <microalgos>]"
    exit 1
  fi

  if ! [[ "$address" =~ ^[A-Z2-7]{58}$ ]]; then
    send_error "Invalid Algorand address: must be 58 uppercase base32 characters"
    exit 1
  fi

  local amount="10000000"
  local i=2
  while [ $i -lt ${#ARGV[@]} ]; do
    case "${ARGV[$i]}" in
      --amount)
        if [ $((i + 1)) -ge ${#ARGV[@]} ]; then
          send_error "--amount requires a value"
          exit 1
        fi
        i=$((i + 1))
        amount="${ARGV[$i]}"
        ;;
    esac
    i=$((i + 1))
  done

  if ! [[ "$amount" =~ ^[0-9]+$ ]]; then
    send_error "Invalid amount: must be a positive integer (microalgos)"
    exit 1
  fi

  if [ "$amount" = "0" ]; then
    send_error "Invalid amount: must be greater than zero"
    exit 1
  fi

  # uint64 max: 18446744073709551615
  if [ ${#amount} -gt 20 ] || { [ ${#amount} -eq 20 ] && [[ "$amount" > "18446744073709551615" ]]; }; then
    send_error "Invalid amount: exceeds uint64 max (18446744073709551615)"
    exit 1
  fi

  check_algokit
  check_docker

  # `algokit goal` resolves the active localnet container regardless of name
  # (current AlgoKit names it `algokit_sandbox_algod`, older releases used
  # `algokit_algod`). The dispenser is the highest-balance account; we sort
  # numerically descending on the microAlgos column and take the first row.
  local result
  result=$(send_exec "fund" "algokit goal clerk send -a '$amount' -f \$(algokit goal account list 2>/dev/null | awk '{print \$3, \$4}' | sort -k2 -n -r | head -1 | awk '{print \$1}') -t '$address'")
  local exit_code
  exit_code=$(resp_code "$result")

  if [ "$exit_code" != "0" ]; then
    local stderr
    stderr=$(resp_stderr "$result")
    send_error "Failed to fund account: $stderr"
    exit 1
  fi

  local algo_amount
  algo_amount=$(echo "scale=6; $amount / 1000000" | bc)
  if [ "$JSON_OUTPUT" = true ]; then
    send_json "$(json_obj --arg a "$address" --arg amt "$algo_amount" --arg micro "$amount" '{ok:true,address:$a,algo:$amt,microalgos:($micro|tonumber)}')"
  else
    send_output "Funded $address with $algo_amount ALGO"
  fi
}

cmd_accounts() {
  check_algokit
  check_docker

  # `algokit goal` finds the active localnet container regardless of its name.
  local result
  result=$(send_exec "accounts" "algokit goal account list 2>/dev/null")
  local exit_code
  exit_code=$(resp_code "$result")

  if [ "$exit_code" != "0" ]; then
    send_error "Localnet is not running. Run: fledge localnet start"
    exit 1
  fi

  local stdout
  stdout=$(resp_stdout "$result")
  if [ -n "$stdout" ]; then
    if [ "$JSON_OUTPUT" = true ]; then
      # Parse `goal account list` output into structured JSON.
      # Each line has the form: [online]  ADDR  BALANCE  microAlgos
      local json_accounts
      json_accounts=$(printf '%s\n' "$stdout" | awk '
        BEGIN { printf "[" ; sep="" }
        /[A-Z2-7]{58}/ {
          for (i=1; i<=NF; i++) {
            if ($i ~ /^[A-Z2-7]{58}$/) { addr=$i }
            if ($i ~ /^[0-9]+$/ && $(i+1) == "microAlgos") { bal=$i }
          }
          printf "%s{\"address\":\"%s\",\"balance\":%s}", sep, addr, bal
          sep=","
        }
        END { printf "]" }
      ')
      send_json "$(json_obj --argjson accts "$json_accounts" '{accounts:$accts}')"
    else
      send "$(printf '%s' "$stdout" | jq -Rsc '{type:"output",text:.}')"
    fi
  else
    if [ "$JSON_OUTPUT" = true ]; then
      send_json '{"accounts":[]}'
    else
      send_output "(no accounts found)"
    fi
  fi
}

cmd_help() {
  send_output "fledge-plugin-localnet — Algorand localnet lifecycle"
  send_output ""
  send_output "Commands:"
  send_output "  start [--json]               Start localnet"
  send_output "  stop [--json]                Stop localnet"
  send_output "  reset [--json]                Reset to genesis"
  send_output "  status [--json]              Show running state"
  send_output "  fund <addr> [--amount N] [--json]  Dispense Algos"
  send_output "  accounts [--json]             List accounts"
  send_output ""
  send_output "Use --json for machine-readable output."
}

case "$SUBCMD" in
  start)    cmd_start ;;
  stop)     cmd_stop ;;
  reset)    cmd_reset ;;
  status)   cmd_status ;;
  fund)     cmd_fund ;;
  accounts) cmd_accounts ;;
  help|--help|-h) cmd_help ;;
  *)
    send_error "Unknown command: $SUBCMD. Run: fledge localnet help"
    exit 1
    ;;
esac
